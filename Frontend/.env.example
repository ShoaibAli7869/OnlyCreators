# OnlyCreators Frontend - Environment Variables
# Copy this file to .env and fill in the values.
# For Vercel deployment, set these in your Vercel project settings.

# Backend API URL (required for production / Vercel deployment)
# Point this to your deployed backend URL, e.g.:
#   https://onlycreators-backend.vercel.app/api
#   https://your-backend.railway.app/api
#   https://your-backend.onrender.com/api
#
# In local development this is NOT needed — the Vite dev server
# proxies /api requests to http://localhost:5000 automatically
# (configured in vite.config.js).
VITE_API_URL=
